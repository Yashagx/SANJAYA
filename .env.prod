# ──────────────────────────────────────────────────────────
# SANJAYA Production Environment Configuration (EC2)
# ──────────────────────────────────────────────────────────

# Database Configuration
# CRITICAL: Update with actual credentials before deployment
DATABASE_URL=postgresql://sanjaya_user:Sanjaya2026!@localhost:5432/sanjaya_db

# ────────────────────────────────────────────────────────────
# Security Keys (CHANGE THESE IN PRODUCTION)
# ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secure-jwt-secret-key-change-in-production-$(date +%s)
ENCRYPTION_KEY=your-secure-encryption-key-change-in-production

# ────────────────────────────────────────────────────────────
# AWS & External APIs
# ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID:-}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:-}
AWS_REGION=ap-south-2

OPENWEATHER_API_KEY=${OPENWEATHER_API_KEY:-}
NEWSCATCHER_API_KEY=${NEWSCATCHER_API_KEY:-}
OPENAI_API_KEY=${OPENAI_API_KEY:-}

# ────────────────────────────────────────────────────────────
# Environment Settings
# ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production

# ────────────────────────────────────────────────────────────
# Admin User
# ────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@sanjaya.local
